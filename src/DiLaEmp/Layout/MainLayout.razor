@inherits LayoutComponentBase
@using System.Globalization
@using DiLaEmp.Localization
@inject IStringLocalizer<CultureDiLaEmp> Loc

<HeadContent>
    <RadzenTheme Theme="material" />
</HeadContent>
<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="about" target="_blank">@Loc["About"]</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>
