@page "/calculator"
@using DiLaEmp.Localization
@using DiLaEmp.Utils.Calendar.Objects
@using DiLaEmpLibrary.Calculators
@inject IStringLocalizer<CultureDiLaEmp> Loc
@inject IJSRuntime JS

<PageTitle>@Loc["Calculator"]</PageTitle>

<div class="d-flex flex-column align-items-start gap-2">
    <div class="form-check">
        <input id="inputCalculateEndDate" class="form-check-input" type="radio" checked="@(isCalculateEndDate)"
               name="Calculate" @onchange="@(() => isCalculateEndDate = true)" />
        <label class="form-check-label" for="inputCalculateEndDate">@Loc["CalculateEndDate"]</label>
    </div>
    
    <div class="form-check">
        <input id="inputCalculateAmountHours" class="form-check-input" type="radio" checked="@(!isCalculateEndDate)"
               name="Calculate" @onchange="@(() => isCalculateEndDate = false)" />
        <label class="form-check-label" for="inputCalculateAmountHours">@Loc["CalculateAmountHours"]</label>
    </div>

    <div class="d-flex align-items-baseline gap-3 p-2 mt-3">
        <div class="form-label text-nowrap">@Loc["StartDate"]: </div>
        <VisualDate @bind-Date="@startDate"/>
    </div>

    <div class="d-flex flex-wrap align-items-baseline gap-3 border p-2">
        <div class="form-label text-nowrap card-title">@Loc["HoursOn"]: </div>
        <HoursByDayOfWeek @bind-HoursOnMonday="@hoursOnMonday" @bind-HoursOnTuesday="@hoursOnTuesday" 
                          @bind-HoursOnWednesday="@hoursOnWednesday" @bind-HoursOnThursday="@hoursOnThursday" 
                          @bind-HoursOnFriday="@hoursOnFriday" @bind-HoursOnSaturday="@hoursOnSaturday"
                          @bind-HoursOnSunday="@hoursOnSunday"/>
    </div>

    <div class="d-flex align-items-baseline gap-3 p-2">
        <div class="form-label text-nowrap">@Loc["AmountHours"]: </div>
        <InputNumber step="0.01" class="form-control" @bind-Value="amountHours" disabled=@{!isCalculateEndDate} />
        <div class="form-label text-nowrap"> @Loc["hours"]</div>
    </div>

    <div class="d-flex align-items-baseline gap-3 p-2">
        <div class="form-label text-nowrap">@Loc["AmountDays"]: </div>
        <InputNumber step="0.01" class="form-control" @bind-Value="amountDays" disabled />
        <div class="form-label text-nowrap"> @Loc["days"]</div>
    </div>

    <div class="d-flex align-items-baseline gap-3 p-2">
        <div class="form-label text-nowrap">@Loc["EndDate"]: </div>
        <VisualDate @bind-Date=@endDate SetDisabled=@isCalculateEndDate />
    </div>
</div>

<div class="align-items-baseline gap-3 p-2 mt-3 mb-4 border">
    <div class="form-label text-nowrap card-title">@Loc["HolidayCalendar"]: </div>
    <div class="gap-3 ms-5">
        <CalendarWrapper @bind-Holidays="@holidays" />
    </div>
</div>

<div class="mb-5">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="5rem" Style="padding: 0.5em">
        <RadzenButton Text="@Loc["Calculate"]"
                      Icon="calculate"
                      Click="@Calculate"
                      ButtonStyle="ButtonStyle.Primary" />
    </RadzenStack>
</div>

@if (showWorkingDays)
{
    <div id="calculatedCalendar" class="mb-5">
        <RadzenScheduler 
                    style="height: 768px;" 
                    TItem="CalendarAppointment" 
                    Data=@appointments 
                    StartProperty="Start" 
                    EndProperty="End" 
                    ShowHeader="true"
                    TextProperty="Text"
                    AppointmentRender="OnAppointmentRender"
                    SlotRender=@OnSlotRender
                    SelectedIndex="0">
@*             
                @ref=@schedulerCalendar
                <RadzenDayView />  //If RadzenDay View and RadzenWeekView are used, then SelectedIndex must be changed (depending the default page you want to show by default).
                <RadzenWeekView /> *@
            <RadzenMonthView />
        </RadzenScheduler>
    </div>
}



@code {
    private DateOnly startDate = DateOnly.FromDateTime(DateTime.UtcNow);
    private DateOnly endDate;
    private decimal amountHours;
    private decimal amountDays;
    private decimal hoursOnMonday = 8;
    private decimal hoursOnTuesday = 8;
    private decimal hoursOnWednesday = 8;
    private decimal hoursOnThursday = 8;
    private decimal hoursOnFriday = 8;
    private decimal hoursOnSaturday = 0;
    private decimal hoursOnSunday = 0;

    //private RadzenScheduler<Appointment> schedulerCalendar;
    private SortedSet<CalendarAppointment> appointments = new();
    private bool showWorkingDays = false;
    private bool shouldScrollToCalculatedCalendar = false;

    private SortedSet<DateTime?> holidays = new SortedSet<DateTime?>();

    private bool isCalculateEndDate = true;

    private async Task Calculate()
    {
        showWorkingDays = false;
        SortedDictionary<DayOfWeek, decimal> hoursByDay = generateHoursByDay();
        SortedSet<DateOnly> holidaysInDateOnly = DateUtils.GetDateOnlysFromDateTimes(holidays);

        if (isCalculateEndDate)
        {
            (endDate, amountDays) = CalculateEndDate.CalculateTheEndDate(startDate, amountHours, hoursByDay, holidaysInDateOnly);
        }
        else
        {
            (amountDays, amountHours) = CalculateAmountDays.CalculateDays(startDate, endDate, hoursByDay, holidaysInDateOnly);
        }

        await ShowCalendar(startDate, endDate, hoursByDay, holidaysInDateOnly);
    }

    private async Task ShowCalendar(DateOnly startDate, DateOnly endDate, SortedDictionary<DayOfWeek, decimal> hoursByDay,
            SortedSet<DateOnly> holidaysInDateOnly)
    {
        showWorkingDays = false;

        appointments = CalculateCalendarAppointment.GenerateCalendarAppointments(
            startDate, 
            endDate, 
            hoursByDay, 
            holidaysInDateOnly, 
            Loc.GetString("Working"), 
            Loc.GetString("Holiday")
        );

        showWorkingDays = true;
        shouldScrollToCalculatedCalendar = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (shouldScrollToCalculatedCalendar)
        {
            shouldScrollToCalculatedCalendar = false;
            await ScrollTo("calculatedCalendar");
        }
    }

    private async Task ScrollTo(string idName)
    {
        await JS.InvokeVoidAsync("scrollToElement", idName);
    }

    private void OnAppointmentRender(SchedulerAppointmentRenderEventArgs<CalendarAppointment> args)
    {
        // Never call StateHasChanged in AppointmentRender - would lead to infinite loop
        if (args.Data is not null)
        {
            if (args.Data.Text == Loc.GetString("Holiday"))
            {
                args.Attributes["style"] = "background: red";
            }
            else if (args.Data.Text == Loc.GetString("Working"))
            {
                args.Attributes["style"] = "background: blue";
            }
        }
    }

    private void OnSlotRender(SchedulerSlotRenderEventArgs args)
    {
        // Highlight today in month view
        if (args.View?.Text == "Month" && args.Start.Date == DateTime.Today)
        {
            args.Attributes["style"] = "background: var(--rz-scheduler-highlight-background-color, rgba(255,220,40,.2));";
        }
    }

    private SortedDictionary<DayOfWeek, decimal> generateHoursByDay()
    {
        return new SortedDictionary<DayOfWeek, decimal>
        {
            { DayOfWeek.Monday, hoursOnMonday },
            { DayOfWeek.Tuesday, hoursOnTuesday },
            { DayOfWeek.Wednesday, hoursOnWednesday },
            { DayOfWeek.Thursday, hoursOnThursday },
            { DayOfWeek.Friday, hoursOnFriday },
            { DayOfWeek.Saturday, hoursOnSaturday },
            { DayOfWeek.Sunday, hoursOnSunday }
        };
    }
}
